void setup() {
  
  pinMode(ldr,INPUT);
  pinMode(ledGreen,OUTPUT);
  pinMode(ledYellow,OUTPUT);
  pinMode(ledRed,OUTPUT);
  pinMode(buzzer,OUTPUT);

  Serial.begin(9600);

  dht.begin();

  lcd.init();
  lcd.backlight();

  RTC.begin();
  RTC.adjust(DateTime(F(__DATE__), F(__TIME__)));

  pinMode(LED_BUILTIN, OUTPUT);
  pinMode(ldr, INPUT);
  pinMode(ledGreen, OUTPUT);
  pinMode(ledYellow, OUTPUT);
  pinMode(ledRed, OUTPUT);
  pinMode(buzzer, OUTPUT);
}

void loop() {
  frame1();
  delay(300);

  frame2();
  delay(300);

  frame3();
  delay(300);

  frame4();
  delay(300);

  frame5();
  delay(300);

  frame6();
  delay(300);

  frame7();
  delay(300);

  frame8();
  delay(300);

  frame2();
  delay(300);

  frame1();
  delay(300);

  DateTime now = RTC.now();

  long adjustedUnix = now.unixtime() + (UTC_OFFSET * 3600);
  DateTime adjustedTime(adjustedUnix);

  float humidity = dht.readHumidity();
  float temperature = dht.readTemperature();

  if (LOG_OPTION) {
    get_log();
  }

  if (adjustedTime.minute() != lastLoggedMinute) {
    lastLoggedMinute = adjustedTime.minute();

    digitalWrite(LED_BUILTIN, HIGH);
    delay(200);
    digitalWrite(LED_BUILTIN, LOW);

    if (temperature < trigger_t_min || temperature > trigger_t_max ||
        humidity < trigger_u_min || humidity > trigger_u_max) {

      int tempInt = (int)(temperature * 100);
      int humiInt = (int)(humidity * 100);

      EEPROM.put(currentAddress, adjustedUnix);
      EEPROM.put(currentAddress + 4, tempInt);
      EEPROM.put(currentAddress + 6, humiInt);

      getNextAddress();
    }
  }

  int valor = analogRead(ldr);
  int luz = map(valor, 0, 1023, 0, 100);
  luz = constrain(luz, 0, 100);

  digitalWrite(ledGreen, LOW);
  digitalWrite(ledYellow, LOW);
  digitalWrite(ledRed, LOW);
  digitalWrite(buzzer, LOW);

  if (luz <= 30) {
    digitalWrite(ledGreen, HIGH);
  }
  else if (luz <= 60) {
    digitalWrite(ledYellow, HIGH);
    digitalWrite(buzzer, HIGH);
    delay(500);
    digitalWrite(buzzer, LOW);
  }
  else {
    digitalWrite(ledRed, HIGH);
  }

  if (SERIAL_OPTION) {
    Serial.print(adjustedTime.timestamp(DateTime::TIMESTAMP_FULL));
    Serial.print(" | Temp: ");
    Serial.print(temperature);
    Serial.print(" C | Umid: ");
    Serial.print(humidity);
    Serial.println(" %");
  }

  if (millis() - ultimoTempo >= 5000) {
    ultimoTempo = millis();
    tela++;

    if (tela > 2) tela = 0;

      int valor = analogRead(ldr);//lê o valor do pino analógico
  int luz = map(valor, 0, 1023,0,100); //converte a leitura para porcentagem
  luz = constrain(luz,0,100);//"constrain()"restringe um número a ficar dentro do intervalo
 
  digitalWrite(ledGreen,LOW);
  digitalWrite(ledYellow,LOW);
  digitalWrite(ledRed,LOW);
 
  unsigned long tempNovo = millis();//armazena o tempo atual
 
//se a porcentagem de luz for menor ou igual a 30, a led
// verde ficará acesa, indicando que a luz está ideal
    if (luz <=30){
        digitalWrite(ledGreen,HIGH);
        digitalWrite(buzzer,LOW);
        buzzerSom = false;

    }
//se a porcentagem de luz for maior ou igual a 60, a led
//amarela ficará acesa, indicando que a luz está em um nível de alerta
    if (luz <60 && luz >30){
        digitalWrite(ledYellow,HIGH);
        digitalWrite(buzzer,HIGH);
        delay(3000);
        digitalWrite(buzzer,LOW);
        delay(3000);
   
    }
//se a porcentagem de luz for maior que 60, a led vermelha ficará
//acesa, indicando que a um problema
     if (luz >60){
        digitalWrite(ledRed,HIGH);
      digitalWrite(ledYellow,LOW);
        buzzerSom = false;
    }
  }

  lcd.clear();

  switch (tela) {
    case 0: // HORÁRIO
      lcd.setCursor(0, 0);
      lcd.print("Horario:");

      lcd.setCursor(0, 1);
      print2digits(adjustedTime.hour());
      lcd.print(":");
      print2digits(adjustedTime.minute());
      lcd.print(":");
      print2digits(adjustedTime.second());
      break;

    case 1: // DATA
      lcd.setCursor(0, 0);
      lcd.print("Data:");

      lcd.setCursor(0, 1);
      print2digits(adjustedTime.day());
      lcd.print("/");
      print2digits(adjustedTime.month());
      lcd.print("/");
      lcd.print(adjustedTime.year());
      break;

    case 2: // TEMPERATURA
      lcd.setCursor(0, 0);
      lcd.print("Temperatura");

      lcd.setCursor(0, 1);
      lcd.print(temperature);
      lcd.print((char)223);
      lcd.print("C");
      break;
  }

  delay(200);
}

void print2digits(int number) {
  if (number < 10) lcd.print("0");
  lcd.print(number);
}

void getNextAddress() {
  currentAddress += recordSize;

  if (currentAddress >= endAddress) {
    currentAddress = 0;
  }
}

void get_log() {
  Serial.println("Data stored in EEPROM:");
  Serial.println("Timestamp\t\tTemperature\tHumidity");

  for (int address = startAddress; address < endAddress; address += recordSize) {
    long timeStamp;
    int tempInt, humiInt;

    EEPROM.get(address, timeStamp);
    EEPROM.get(address + 4, tempInt);
    EEPROM.get(address + 6, humiInt);

    float temperature = tempInt / 100.0;
    float humidity = humiInt / 100.0;

    if (timeStamp != 0xFFFFFFFF && timeStamp != 0) {
      DateTime dt(timeStamp);
      Serial.print(dt.timestamp(DateTime::TIMESTAMP_FULL));
      Serial.print("\t");
      Serial.print(temperature);
      Serial.print(" C\t");
      Serial.print(humidity);
      Serial.println(" %");
    }
  }
}
